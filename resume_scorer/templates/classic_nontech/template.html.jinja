<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
@page { size: letter; margin: 0.75in; }
body {
  font-family: "Liberation Serif", Georgia, "Times New Roman", serif;
  font-size: 11pt;
  color: #1a1a1a;
  line-height: 1.4;
}
.header { text-align: center; margin-bottom: 14pt; border-bottom: 2px solid #333; padding-bottom: 8pt; }
.name { font-size: 16pt; font-weight: bold; margin-bottom: 4pt; }
.contact { font-size: 10pt; color: #444; }
.section { margin-top: 12pt; margin-bottom: 8pt; }
.section-title {
  font-size: 12pt;
  font-weight: bold;
  border-bottom: 1px solid #666;
  padding-bottom: 2pt;
  margin-bottom: 6pt;
}
.entry-header { font-weight: bold; margin-top: 6pt; }
.entry-dates { float: right; font-weight: normal; font-style: italic; }
ul { margin: 3pt 0 6pt 18pt; padding: 0; }
li { margin-bottom: 3pt; }
.skills { margin: 3pt 0; }
p { margin: 3pt 0; }
</style>
</head>
<body>
<div class="header">
  <div class="name">{{ name }}</div>
  <div class="contact">
    {% if contact.email %}{{ contact.email }}{% endif %}
    {% if contact.phone %} &bull; {{ contact.phone }}{% endif %}
    {% if contact.linkedin %} &bull; {{ contact.linkedin }}{% endif %}
  </div>
</div>

{% if summary %}
<div class="section">
  <div class="section-title">Professional Summary</div>
  <p>{{ summary }}</p>
</div>
{% endif %}

{% if experience %}
<div class="section">
  <div class="section-title">Professional Experience</div>
  {% for exp in experience %}
  <div class="entry-header">
    {% if exp.dates %}<span class="entry-dates">{{ exp.dates }}</span>{% endif %}
    {{ exp.title }}{% if exp.company %}, {{ exp.company }}{% endif %}
  </div>
  {% if exp.bullets %}
  <ul>
    {% for bullet in exp.bullets %}
    <li>{{ bullet }}</li>
    {% endfor %}
  </ul>
  {% endif %}
  {% endfor %}
</div>
{% endif %}

{% if education %}
<div class="section">
  <div class="section-title">Education</div>
  {% for edu in education %}
  <div class="entry-header">
    {% if edu.dates %}<span class="entry-dates">{{ edu.dates }}</span>{% endif %}
    {{ edu.degree }}{% if edu.institution %}, {{ edu.institution }}{% endif %}
  </div>
  {% endfor %}
</div>
{% endif %}

{% if skills %}
<div class="section">
  <div class="section-title">Skills &amp; Competencies</div>
  <p class="skills">{{ skills | join(' &bull; ') }}</p>
</div>
{% endif %}

{% if projects %}
<div class="section">
  <div class="section-title">Projects</div>
  {% for proj in projects %}
  <div class="entry-header">{{ proj.name }}</div>
  {% if proj.description %}<p>{{ proj.description }}</p>{% endif %}
  {% if proj.bullets %}
  <ul>
    {% for bullet in proj.bullets %}
    <li>{{ bullet }}</li>
    {% endfor %}
  </ul>
  {% endif %}
  {% endfor %}
</div>
{% endif %}

</body>
</html>
