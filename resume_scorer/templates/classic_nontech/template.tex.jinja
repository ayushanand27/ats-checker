\documentclass[letterpaper,11pt]{article}
\usepackage[empty]{fullpage}
\usepackage{titlesec}
\usepackage{enumitem}
\usepackage[hidelinks]{hyperref}
\usepackage{fancyhdr}
\usepackage[english]{babel}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\urlstyle{same}
\setlength{\tabcolsep}{0in}
\setlength{\parindent}{0pt}
\titleformat{\section}{\large\bfseries}{}{0em}{}[\titlerule]
\titlespacing{\section}{0pt}{12pt}{8pt}

\begin{document}

\begin{center}
    {\LARGE \textbf{ {{ name }} }} \\[6pt]
    {% if contact.email %}{{ contact.email | latex }}{% endif %}
    {% if contact.phone %} \textbullet{} {{ contact.phone | latex }}{% endif %}
    {% if contact.linkedin %} \textbullet{} \href{ {{ contact.linkedin }} }{LinkedIn}{% endif %}
\end{center}

{% if summary %}
\section{Professional Summary}
{{ summary }}
{% endif %}

{% if experience %}
\section{Professional Experience}
{% for exp in experience %}
\textbf{ {{ escape_latex(exp.title) }} }{% if exp.company %}, {{ escape_latex(exp.company) }}{% endif %}{% if exp.dates %} \hfill {{ escape_latex(exp.dates) }}{% endif %}
\begin{itemize}[leftmargin=*, nosep]
{% for bullet in exp.bullets %}
    \item {{ escape_latex(bullet) }}
{% endfor %}
\end{itemize}
{% endfor %}
{% endif %}

{% if education %}
\section{Education}
{% for edu in education %}
\textbf{ {{ escape_latex(edu.degree) }} }{% if edu.institution %}, {{ escape_latex(edu.institution) }}{% endif %}{% if edu.dates %} \hfill {{ escape_latex(edu.dates) }}{% endif %} \\[2pt]
{% endfor %}
{% endif %}

{% if skills %}
\section{Skills \& Competencies}
{{ skills | join(' \textbullet{} ') }}
{% endif %}

{% if projects %}
\section{Projects}
{% for proj in projects %}
\textbf{ {{ escape_latex(proj.name) }} }
{% if proj.description %}{{ escape_latex(proj.description) }}{% endif %}
\begin{itemize}[leftmargin=*, nosep]
{% for bullet in proj.bullets %}
    \item {{ escape_latex(bullet) }}
{% endfor %}
\end{itemize}
{% endfor %}
{% endif %}

\end{document}
